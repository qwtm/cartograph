{
  "problemMatcher": [
    {
      "owner": "cargo-rustc",
      "pattern": [
        {
          "regexp": "^(error|warning)(?:\\[(\\S+)\\])?: (.+)$",
          "severity": 1,
          "code": 2,
          "message": 3
        },
        {
          "regexp": "^\\s+-->\\s+(\\S+):(\\d+):(\\d+)$",
          "file": 1,
          "line": 2,
          "column": 3
        }
      ]
    }
  ]
}
